<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="
                   http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260616114100" author="BrunoMartucci">

        <createTable tableName="antecipacao_marketplace">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="marketplace_id" type="BIGINT"/>

            <column name="data_antecipacao" type="DATE"/>

            <column name="valor_original" type="DECIMAL(15,2)"/>

            <column name="taxa_percentual" type="DECIMAL(10,2)"/>

            <column name="valor_taxa" type="DECIMAL(15,2)"/>

            <column name="valor_liquido" type="DECIMAL(15,2)"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="antecipacao_marketplace"
                baseColumnNames="marketplace_id"
                referencedTableName="marketplace"
                referencedColumnNames="id"
                constraintName="fk_antecipacao_marketplace"/>

    </changeSet>

</databaseChangeLog>