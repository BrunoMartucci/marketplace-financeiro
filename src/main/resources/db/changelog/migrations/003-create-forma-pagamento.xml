<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="
                   http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260616113800" author="BrunoMartucci">

        <createTable tableName="forma_pagamento_marketplace">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="marketplace_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="nome" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="prazo_recebimento" type="INT"/>

            <column name="permite_antecipacao" type="BOOLEAN"/>

            <column name="integra_cartao" type="BOOLEAN"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="forma_pagamento_marketplace"
                baseColumnNames="marketplace_id"
                referencedTableName="marketplace"
                referencedColumnNames="id"
                constraintName="fk_forma_pagamento_marketplace"/>

    </changeSet>

</databaseChangeLog>