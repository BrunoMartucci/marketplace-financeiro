<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="
                   http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260616113900" author="BrunoMartucci">

        <createTable tableName="pedido_marketplace">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="marketplace_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="codigo_marketplace" type="VARCHAR(100)"/>

            <column name="valor_bruto" type="DECIMAL(15,2)"/>

            <column name="valor_entrega" type="DECIMAL(15,2)"/>

            <column name="data_pedido" type="DATETIME"/>

            <column name="status" type="VARCHAR(30)"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="pedido_marketplace"
                baseColumnNames="marketplace_id"
                referencedTableName="marketplace"
                referencedColumnNames="id"
                constraintName="fk_pedido_marketplace"/>

    </changeSet>

</databaseChangeLog>